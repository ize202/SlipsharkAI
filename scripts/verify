#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
repo_root="$(dirname -- "$script_dir")"

if [[ "$(pwd -P)" != "$repo_root" ]]; then
  echo "Run ./scripts/verify from the repository root: $repo_root" >&2
  exit 2
fi

if (( $# != 0 )); then
  echo "Usage: ./scripts/verify" >&2
  exit 2
fi

uv lock --check
uv sync --frozen --all-groups
uv run ruff format --check .
uv run ruff check .
uv run mypy src/slipshark
uv run pytest -q
uv run python scripts/smoke.py
uv run python scripts/demo.py
