# Required in every environment. Use local, test, or production.
SLIPSHARK_ENVIRONMENT=local
SLIPSHARK_HOST=127.0.0.1
SLIPSHARK_PORT=8000

# Server-side provider credentials. Replace these placeholders outside source control.
SLIPSHARK_OPENAI_API_KEY=replace-with-openai-api-key
SLIPSHARK_EXA_API_KEY=replace-with-exa-api-key

# JSON object mapping stable principal IDs to long, random server-to-server keys.
SLIPSHARK_API_KEYS={"trusted-backend":"replace-with-a-long-random-api-key"}

# Local example only. Production should use its managed Redis connection string.
SLIPSHARK_REDIS_URL=redis://localhost:6379/0

# Never ship API keys, provider credentials, or the Redis URL to a browser or mobile app.
# A protected calling server keeps X-API-Key; OpenAI, Exa, and Redis secrets stay here.
